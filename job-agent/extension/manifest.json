{
  "manifest_version": 3,
  "name": "AI Job Application Agent",
  "version": "0.1.0",
  "description": "Review-first job application copilot.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "AI Job Agent",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/dom_utils.js",
        "lib/portal_detector.js",
        "content/extractor.js",
        "content/form_mapper.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
